# /etc/caddy/Caddyfile  —  after editing: sudo caddy validate --config /etc/caddy/Caddyfile
#                                        sudo systemctl reload caddy
#
# This file MIRRORS what is actually running on 13.234.60.18. Keep it that way:
# the live config and this file drifted apart once already (the repo said
# api.gymsetu.it.com while the box was serving nip.io), which makes the repo
# actively misleading during an incident. Edit here, then push to the server.
#
# Live hostnames today (both get real Let's Encrypt certs, no DNS work needed —
# nip.io resolves any *.13.234.60.18.nip.io name straight to the Elastic IP):
#   https://13.234.60.18.nip.io       -> Supabase API (Kong)
#   https://app.13.234.60.18.nip.io   -> the GymSetu PWA
#
# The gymsetu.it.com blocks are the intended permanent names. They stay in the
# config while their DNS is still missing: Caddy retries issuance for 30 days,
# so the cert appears on its own once the A record exists. Until then the nip.io
# hostnames keep serving — which is exactly why each name gets its OWN block
# rather than being listed together. In a shared block, one unresolvable name's
# failed ACME challenge takes the whole block's certificate down with it.

# ── Supabase API -> Kong ───────────────────────────────────────────────────
13.234.60.18.nip.io {
    reverse_proxy localhost:8000
}

api.gymsetu.it.com {
    reverse_proxy localhost:8000
}

# ── GymSetu PWA (expo export --platform web, SPA "single" output) ───────────
# Deploy with:
#   cd app && npx expo export --platform web
#   tar -czf /tmp/gymsetu-app.tgz -C dist .
#   scp -i gynmsetu.pem /tmp/gymsetu-app.tgz ubuntu@13.234.60.18:/tmp/
#   ssh ... 'sudo rm -rf /var/www/gymsetu-app/* &&
#            sudo tar -xzf /tmp/gymsetu-app.tgz -C /var/www/gymsetu-app &&
#            sudo chown -R caddy:caddy /var/www/gymsetu-app'
# No Caddy reload needed for a redeploy — it serves from disk.
(gymsetu_app) {
    # Health probe for external uptime monitoring. MUST come before the SPA
    # fallback below, or try_files swallows /healthz and serves index.html —
    # which returns 200 with the app's HTML and would make a status-code-only
    # monitor report green while the database is on fire.
    # Written every 5 min by /usr/local/bin/gymsetu-health. Always 200; the
    # monitor must alert on the body not containing "OK", not on the status.
    handle /healthz {
        root * /var/www/health
        rewrite * /status.txt
        header Content-Type "text/plain"
        header Cache-Control "no-store"
        file_server
    }

    # Everything else is the app. Both branches are `handle` blocks so they're
    # mutually exclusive and evaluated in written order — mixing a handle with
    # bare directives in one site makes Caddy's routing order subtle.
    handle {
        root * /var/www/gymsetu-app
        encode gzip zstd

        # Filenames are content-hashed, so they can never go stale.
        @immutable path /_expo/* /assets/*
        header @immutable Cache-Control "public, max-age=31536000, immutable"

        # index.html is the ONE file that must not be cached: it names the
        # current bundle hash, so a cached copy pins clients to a dead bundle.
        header /index.html Cache-Control "no-cache, must-revalidate"

        # expo-router owns routing; unknown paths must render the SPA, not 404,
        # or a hard refresh on a deep link like /members/123 breaks.
        try_files {path} /index.html
        file_server
    }
}

app.13.234.60.18.nip.io {
    import gymsetu_app
}

app.gymsetu.it.com {
    import gymsetu_app
}

# ── Biometric devices (ZKTeco / eSSL "ADMS" push) ──────────────────────────
# Plain HTTP on a dedicated port, deliberately. These devices frequently cannot
# do TLS at all, and older firmware has no Let's Encrypt root, so an HTTPS-only
# endpoint fails SILENTLY — the gym just stops getting attendance with no error
# anywhere. The payload is a PIN and a timestamp; the trade is worth it.
#
# The firmware hard-codes the /iclock/ path, so rewrite onto the edge function
# and inject the apikey the device has no way to send.
#
# REQUIRED: open TCP 8090 in the EC2 security group, or devices cannot reach it.
# Point the device at:  Comm. > Cloud Server > IP 13.234.60.18, Port 8090
:8090 {
    handle /iclock/* {
        rewrite * /functions/v1/biometric-push{uri}
        reverse_proxy localhost:8000 {
            header_up apikey "<ANON_KEY>"
            header_up Authorization "Bearer <ANON_KEY>"
        }
    }
    handle {
        respond "GymSetu biometric endpoint" 200
    }
}
