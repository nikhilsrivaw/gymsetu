# EXTRA keys to append to supabase/docker/.env for GymSetu.
# (These are in ADDITION to Supabase's own .env — don't remove theirs.)

# --- App edge function secrets (read by docker-compose.override.yml) ---
GROQ_API_KEY=gsk_replace_me
WHATSAPP_PHONE_NUMBER_ID=replace_me
WHATSAPP_ACCESS_TOKEN=replace_me
WEBHOOK_SECRET=gymsetu_webhook_2026

# --- Website edge function secrets (PayU + Gemini) ---
PAYU_MERCHANT_KEY=replace_me
PAYU_SALT=replace_me
PAYU_MODE=test
APP_URL=https://gymsetu.it.com
GEMINI_API_KEY=replace_me

# --- Reminders of the core values you must also set in supabase/docker/.env ---
# POSTGRES_PASSWORD=<openssl rand -hex 24>
# JWT_SECRET=<openssl rand -hex 40>
# ANON_KEY=<from: node deploy/gen-keys.mjs "$JWT_SECRET">
# SERVICE_ROLE_KEY=<from the same command>
# DASHBOARD_USERNAME=admin
# DASHBOARD_PASSWORD=<strong>
# SITE_URL=https://api.gymsetu.it.com
# API_EXTERNAL_URL=https://api.gymsetu.it.com
# SUPABASE_PUBLIC_URL=https://api.gymsetu.it.com
# ENABLE_EMAIL_AUTOCONFIRM=true
